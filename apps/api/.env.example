# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth (Sign in with Apple) ---
# Secret used to sign Meridian session tokens. Any long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_JWT_SECRET="change-me-to-a-long-random-string"

# Must match the iOS app bundle identifier (the `aud` in Apple's token).
APPLE_BUNDLE_ID="com.elysiumventures.meridian"

# --- Two-user allowlist ---
# Exactly the two emails permitted to use the app. Anyone else is rejected 403.
ALLOWED_EMAILS="aatir@example.com,brother@example.com"

# Stable A/B slot assignment for daily_results. A is the canonical first column.
USER_A_EMAIL="aatir@example.com"
USER_B_EMAIL="brother@example.com"

# Display names, JSON keyed by email. Authoritative source for users.name.
USER_NAMES='{"aatir@example.com":"Aatir","brother@example.com":"Bro"}'

# --- App config ---
APP_TIMEZONE="America/New_York"

# Vercel cron backstop guard. Generate a random string.
CRON_SECRET="change-me"

# Neutral-day feature flag. Ship off.
ENABLE_NEUTRAL_DAYS="false"
