{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "image": "sdk-55"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "store",
      "ios": {
        "simulator": false,
        "autoIncrement": true,
        "image": "sdk-55"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://meridian-api.vercel.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "image": "sdk-55"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://meridian-api.vercel.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {}
    }
  }
}
